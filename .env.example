AGENT_MODE=mock
SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
SESSION_SECRET=replace-with-a-long-random-value
BEHAVIORAL_MODE=fewshot
# Agent activation is separate from the classifier strategy above.
BEHAVIORAL_AGENT_MODE=
# Per-agent real mode can be enabled without changing the safe global default.
FORENSICS_AGENT_MODE=
TRANSCRIBE_AGENT_MODE=
REGISTRY_AGENT_MODE=
SERVING_ENDPOINT=
CHAT_ENDPOINT=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
# Used only by Image Scanner authenticity analysis.
IMAGE_FORENSICS_MODEL=google/gemini-2.5-pro
VS_ENDPOINT=
VS_INDEX=
# Databricks Vector Search resolves service-principal credentials in Apps.
# Local SDK authentication can use DATABRICKS_HOST + DATABRICKS_TOKEN instead.
DATABRICKS_HOST=
DATABRICKS_TOKEN=
ELEVENLABS_API_KEY=
EL_VOICE_ID=
ELEVENLABS_AGENT_ID=agent_your_agent_id
ELEVENLABS_BRANCH_ID=agtbrch_your_branch_id
# Optional. DJAGA creates and remembers this text-document ID on the first
# knowledge-base sync; set it explicitly in Render to pin a specific document.
ELEVENLABS_KB_DOCUMENT_ID=
# Set a long random string and use the same value as the x-djaga-tool-secret
# header in the ElevenLabs custom tool configuration.
ELEVENLABS_TOOL_SECRET=
EXA_API_KEY=
# Enable individual agents with AGENT_MODE=real:behavioral,registry,osint
# or override a single agent, e.g. IMAGE_FORENSICS_MODE=real.
VOICE_FORENSICS_MODEL=google/gemini-3.1-flash-lite
IMAGE_MODEL_ID=jacoballessio/ai-image-detect-distilled
HF_TOKEN=
